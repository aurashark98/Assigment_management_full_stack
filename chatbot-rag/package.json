{
  "name": "chatbot-rag-assignment-management",
  "version": "1.0.0",
  "description": "RAG-based chatbot for Assignment Management system using Anthropic Claude or Ollama",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test src/**/*.test.js",
    "reindex": "node src/scripts/reindex.js",
    "setup:anthropic": "node src/scripts/setup-anthropic.js",
    "setup:ollama": "node src/scripts/setup-ollama.js"
  },
  "keywords": [
    "chatbot",
    "RAG",
    "assignment-management",
    "claude",
    "anthropic",
    "semantic-search",
    "ollama"
  ],
  "author": "Assignment Management Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "axios": "^1.6.0",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
